name: Build Java Application

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v2

    - name: Set up JDK 11
      uses: actions/setup-java@v2
      with:
        java-version: '20'
        distribution: 'temurin'

    - name: Build with Maven
      run: mvn package

    - name: Upload JAR
      uses: actions/upload-artifact@v2
      with:
        name: application-jar
        path: target/*.jar
